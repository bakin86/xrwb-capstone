# .dockerignore – exclude files that should not be sent to the Docker build context

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/
env/
ENV/

# Django
*.sqlite3
db.sqlite3
staticfiles/
media/

# Node / React (built separately)
node_modules/
frontend/node_modules/

# Version control
.git/
.gitignore

# CI / editor artefacts
.env
.env.*
.idea/
.vscode/
*.log
